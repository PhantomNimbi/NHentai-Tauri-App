{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NHentai",
  "version": "1.0.1",
  "identifier": "net.nhentai.tauri",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "nhentai"
        ]
      }
    }
  }
}
